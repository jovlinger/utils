# Public template - copy to config/<name>.env, commit it, and set THERMO_ENV_FILE for deploy.
#
# Example: cp config/deploy.env.sample config/example.env
#          export THERMO_ENV_FILE=config/example.env
#
# Docker Compose defaults in onboard/hardware/pizero2w/install/docker-compose.yml
# should match these values for Pi Zero 2 W deployments.
DMZ_SCHEME=http
DMZ_HOST=192.168.1.45
DMZ_PORT=5000

# Onboard deployment identity. ZONE_NAME is the DMZ/UI key; keep it unique per unit.
ZONE_NAME=kitchen

# Room deployment destination. `make -C thermo/onboard deploy` dispatches to this backend.
ONBOARD_DEPLOY_BACKEND=pizero2w
ONBOARD_DEPLOY_HOST=pizerokitchen.local
ONBOARD_DEPLOY_USER=johan
ONBOARD_DEPLOY_REPO=/home/johan/github.com/jovlinger/utils
ONBOARD_DEPLOY_ENV_FILE=config/kitchen.env

# Physical hardware profile and selected behaviors for this onboard.
ONBOARD_HARDWARE_PROFILE=pi_zero_2w_htu21d_ir
ONBOARD_SEND_BEHAVIOR=ir_daikin
ONBOARD_REPORT_BEHAVIOR=sensor_readings
SENSOR_DRIVER=htu21d
IR_TRANSPORT=lirc
IR_DEVICE=/dev/lirc0
