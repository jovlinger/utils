# Public template — copy to config/<name>.env (gitignored) and set THERMO_ENV_FILE for deploy.
#
# Example: cp config/deploy.env.sample config/kitchen.env
#          export THERMO_ENV_FILE=config/kitchen.env
#
# Docker Compose defaults in onboard/install/docker-compose.yml should match these values.
DMZ_SCHEME=http
DMZ_HOST=jovlinger.duckdns.org
DMZ_PORT=5000
