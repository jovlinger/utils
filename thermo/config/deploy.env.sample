# Public template - copy to config/<name>.env (gitignored) and set THERMO_ENV_FILE for deploy.
#
# Example: cp config/deploy.env.sample config/kitchen.env
#          export THERMO_ENV_FILE=config/kitchen.env
#
# Docker Compose defaults in onboard/install/docker-compose.yml should match these values.
DMZ_SCHEME=http
DMZ_HOST=jovlinger.duckdns.org
DMZ_PORT=5000

# Onboard deployment identity. ZONE_NAME is the DMZ/UI key; keep it unique per unit.
ZONE_NAME=kitchen

# Physical hardware profile and selected behaviors for this onboard.
ONBOARD_HARDWARE_PROFILE=pi_zero_2w_htu21d_ir
ONBOARD_SEND_BEHAVIOR=ir_daikin
ONBOARD_REPORT_BEHAVIOR=sensor_readings
SENSOR_DRIVER=htu21d
IR_TRANSPORT=lirc
IR_DEVICE=/dev/lirc0
