DMZ_SCHEME=http
DMZ_HOST=jovlinger.duckdns.org
DMZ_PORT=5000

ZONE_NAME=kitchen

ONBOARD_DEPLOY_BACKEND=pico2w
ONBOARD_DEPLOY_ENV_FILE=config/kitchen-pico2w.env

ONBOARD_HARDWARE_PROFILE=pico2w_aht20_ir
ONBOARD_SEND_BEHAVIOR=ir_daikin
ONBOARD_REPORT_BEHAVIOR=sensor_readings
SENSOR_DRIVER=aht20
SENSOR_BOOT_REQUIRED=0
IR_TRANSPORT=pico_gpio
IR_DEVICE=gp14
IR_RECEIVER_DEVICE=gp15

PICO2W_IMPLEMENTATION=rust
PICO2W_TARGET=thumbv8m.main-none-eabihf
PICO2W_DEPLOY_ACTION=check
PICO2W_WIFI_SSID=lumiere
PICO2W_POST_TIMEOUT_SECS=600
# Set these once the firmware build emits a UF2 and the board is in BOOTSEL mode.
# PICO2W_DEPLOY_ACTION=flash
# PICO2W_UF2_PATH=thermo/onboard/hardware/pico2w/target/thumbv8m.main-none-eabihf/release/thermo-pico2w.uf2
# PICO2W_UF2_VOLUME=/Volumes/RPI-RP2
PICO2W_I2C_BUS=i2c0
PICO2W_AHT20_SDA_GPIO=gp4
PICO2W_AHT20_SCL_GPIO=gp5
PICO2W_AHT20_ADDR=0x38
PICO2W_STATUS_LED_DRIVER=cyw43_ledw
