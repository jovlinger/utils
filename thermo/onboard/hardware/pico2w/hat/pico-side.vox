# net 3V3 P5.c1 P17.c3 P14.c3 P6.c3
# disjoint GND 3V3
# net SDA P6.c8 P6.c6
# disjoint SDA GND
# disjoint SDA 3V3
# net SCL P7.c8 P6.c5
# disjoint SDA SCL
# disjoint SCL GND
# disjoint SCL 3V3
# net OUT P17.c8 P17.c5
# disjoint OUT SDA
# disjoint OUT SCL
# disjoint OUT GND
# disjoint OUT 3V3
# net DAT P14.c8 P14.c5
# disjoint OUT DAT
# disjoint DAT SDA
# disjoint DAT SCL
# disjoint DAT GND
