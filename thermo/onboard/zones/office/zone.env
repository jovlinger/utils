# Office zone: ESP32-S3 + AHT20 + IR TX/RX (Midea / Coolix).
# GPIO: hardware/esp32s3/hat/one-side.vox

DMZ_SCHEME=http
DMZ_HOST=jovlinger.duckdns.org
DMZ_PORT=5000

ZONE_NAME=office
ZONE_PRIVATE_KEY_PATH=$THERMO_ROOT/priv/zone/priv.pem

ONBOARD_DEPLOY_BACKEND=esp32s3
ONBOARD_DEPLOY_ENV_FILE=onboard/zones/office/zone.env
ESP32S3_PRIV_ENV=$THERMO_ROOT/priv/esp32s3/office.env

ONBOARD_HARDWARE_PROFILE=esp32s3_aht20_ir
ONBOARD_SEND_BEHAVIOR=ir_heatpump
ONBOARD_IR_PROTOCOL=midea24_coolix
ONBOARD_REPORT_BEHAVIOR=sensor_readings
SENSOR_DRIVER=aht20
SENSOR_BOOT_REQUIRED=0

IR_TRANSPORT=esp32s3_rmt
IR_DEVICE=gpio17

ESP32S3_WIFI_SSID=lumiere
ESP32S3_POST_TIMEOUT_SECS=600
ESP32S3_IR_TX_GPIO=17
ESP32S3_IR_RX_GPIO=6
ESP32S3_AHT20_SDA_GPIO=8
ESP32S3_AHT20_SCL_GPIO=9
ESP32S3_AHT20_ADDR=0x38
ESP32S3_STATUS_LED_DRIVER=log_only

# Jaguar identity (must not collide with picopi onboard name thermo-office).
ESP32S3_JAGUAR_DEVICE_NAME=esp32s3-office
ESP32S3_JAGUAR_CONTAINER_NAME=thermo-esp32s3
# Optional DHCP fallback when the device has not been renamed yet (update after rename).
ESP32S3_JAGUAR_DEVICE_ADDRESS=192.168.88.73

# Optional: override autodetected flash port (COM/UART USB-C bridge).
# ESP32S3_FLASH_PORT=/dev/cu.wchusbserial110
