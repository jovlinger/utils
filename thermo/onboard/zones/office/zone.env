# Office zone: Pico2W + AHT20 + IR TX/RX (Midea).
# GPIO: hardware/pico2w/hat/pico-side.vox (pico-side HAT).

DMZ_SCHEME=http
DMZ_HOST=jovlinger.duckdns.org
DMZ_PORT=5000

ZONE_NAME=office
ZONE_PRIVATE_KEY_PATH=$THERMO_ROOT/priv/zone/priv.pem

ONBOARD_DEPLOY_BACKEND=pico2w
ONBOARD_DEPLOY_ENV_FILE=onboard/zones/office/zone.env
PICO2W_PRIV_ENV=$THERMO_ROOT/priv/pico2w/office.env

ONBOARD_HARDWARE_PROFILE=pico2w_aht20_ir
ONBOARD_SEND_BEHAVIOR=ir_heatpump
ONBOARD_IR_PROTOCOL=midea_classic
ONBOARD_REPORT_BEHAVIOR=sensor_readings
SENSOR_DRIVER=aht20
SENSOR_BOOT_REQUIRED=0

IR_TRANSPORT=pico_gpio
IR_DEVICE=gp10
IR_RECEIVER_DEVICE=gp13

PICO2W_IMPLEMENTATION=rust
PICO2W_TARGET=thumbv8m.main-none-eabihf
PICO2W_WIFI_SSID=lumiere
PICO2W_POST_TIMEOUT_SECS=600
PICO2W_UF2_PATH=$THERMO_ROOT/onboard/hardware/pico2w/target/thumbv8m.main-none-eabihf/release/ledw_status_rp2350.uf2
PICO2W_UF2_VOLUME=/Volumes/RP2350

# Firmware uses software I2C on these pins (not hardware i2c0).
PICO2W_AHT20_SDA_GPIO=gp28
PICO2W_AHT20_SCL_GPIO=gp27
PICO2W_AHT20_ADDR=0x38
PICO2W_STATUS_LED_DRIVER=cyw43_ledw
