    "zone_name": "office",
    "send_behavior": "ir_heatpump",
    "report_behavior": "sensor_readings",
    "sensor_driver": "aht20",
    "ir_transport": "esp32s3_rmt",
    "ir_device": "gpio17",
    "ir_protocol": "midea24_coolix",
    "backend": "esp32s3",
    "status_led_driver": "log_only"
  },
  "expected_body_json": "{\"sensors\":{\"temp_centigrade\":21.0,\"humid_percent\":50.0},\"deployment\":{\"hardware_profile\":\"esp32s3_aht20_ir\",\"zone_name\":\"office\",\"send_behavior\":\"ir_heatpump\",\"report_behavior\":\"sensor_readings\",\"sensor_driver\":\"aht20\",\"ir_transport\":\"esp32s3_rmt\",\"ir_device\":\"gpio17\",\"ir_protocol\":\"midea24_coolix\",\"backend\":\"esp32s3\",\"status_led_driver\":\"log_only\"}}",
