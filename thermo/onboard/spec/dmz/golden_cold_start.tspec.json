{
  "$tsl": "1.0",
  "kind": "dmz_golden",
  "name": "office_esp32s3_cold_start",
  "source": "thermo/onboard/hardware/esp32s3/PLAN.md section 3 + zone.env",
  "zone_name": "office",
  "reading": {
    "temp_centigrade": 21.0,
    "humid_percent": 50.0
  },
  "last_applied_command_json": null,
  "include_network": false,
  "include_logs": false,
  "deployment": {
