# Copy to .env in this directory (same folder as docker-compose.yml) or export in ~/.local.sh
# deploy-compose.sh requires THERMO_ENV_FILE (e.g. export THERMO_ENV_FILE=config/kitchen.env), then sources ~/.local.sh.
# DMZ_* defaults come from that file (see ../../config/deploy.env.sample).
#
# Override DMZ only if needed:
# DMZ_HOST=192.168.88.200
# DMZ_PORT=5000
# or a full URL:
# DMZ_URL=http://192.168.88.200:5000

# Onboard HTTP API (host network: loopback is correct)
ONBOARD_URL=http://127.0.0.1:5000

# Zone path segment for /zone/<name>/sensors. Prefer setting this in THERMO_ENV_FILE.
ZONE_NAME=kitchen

# Onboard deployment choices. Prefer setting these in THERMO_ENV_FILE.
ONBOARD_HARDWARE_PROFILE=pi_zero_2w_htu21d_ir
ONBOARD_SEND_BEHAVIOR=ir_daikin
ONBOARD_REPORT_BEHAVIOR=sensor_readings
SENSOR_DRIVER=htu21d
IR_TRANSPORT=lirc
IR_DEVICE=/dev/lirc0

# Match DMZ long-poll (default 60s). Twoway DMZ POST timeout = this + 10s unless DMZ_HTTP_TIMEOUT_SECS is set.
# LONG_POLL_TIMEOUT_SECS=60

# Zone machine auth (twoway → DMZ): set ZONE_PRIVATE_KEY_PATH after bind-mounting keys (see ../KEYS-AND-CERTS.md).
# ZONE_PRIVATE_KEY_PATH=/keys/priv.pem

# Skip onboard HTML UI (use DMZ ui_server on :8090 / your DMZ UI_PORT instead).
# THERMO_UI_DISABLE=1

# Host directory for bind-mounted logs (default shown)
# Preferred for SD wear reduction: mount this path as tmpfs on the host
# (example fstab entry: tmpfs /var/log/thermo-onboard tmpfs rw,nosuid,nodev,mode=0755,size=16m 0 0)
# THERMO_LOG_DIR=/var/log/thermo-onboard

# Optional: force image platform on Pi (usually auto)
# DOCKER_DEFAULT_PLATFORM=linux/arm/v7

# Optional: start connectivity-watchdog (needs twoway image built with connectivity_watchdog
# + docker-entrypoint-watchdog.sh — enable after `make push` / CI refreshes GHCR).
# COMPOSE_PROFILES=thermo-watchdog
